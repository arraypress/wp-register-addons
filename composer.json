{
  "name": "arraypress/wp-register-addons",
  "version": "1.0.0",
  "description": "A declarative WordPress add-ons page registration system for showcasing pro extensions and features",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "homepage": "https://github.com/arraypress/wp-register-addons/",
  "authors": [
    {
      "name": "David Sherlock",
      "homepage": "https://arraypress.com/"
    }
  ],
  "require": {
    "php": ">=7.4",
    "arraypress/wp-composer-assets": "dev-main"
  },
  "autoload": {
    "psr-4": {
      "ArrayPress\\RegisterAddons\\": "src/"
    },
    "files": [
      "src/Functions.php"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "preferred-install": "dist"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "support": {
    "issues": "https://github.com/arraypress/wp-register-addons/issues",
    "source": "https://github.com/arraypress/wp-register-addons"
  },
  "keywords": [
    "wordpress",
    "addons",
    "extensions",
    "pro",
    "upsell",
    "admin-interface",
    "wp-admin",
    "plugin-marketplace"
  ]
}
